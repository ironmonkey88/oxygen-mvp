{
  "permissions": {
    "allow": [
      "Bash(ssh oxygen-mvp *)",
      "Bash(scp *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show)",
      "Bash(git -C * show *)",
      "Bash(git -C * ls-tree *)",
      "Bash(git -C * ls-files *)",
      "Bash(git -C * remote -v)",
      "Bash(git -C * worktree list)",
      "Bash(git -C * branch)",
      "Bash(git -C * branch -v)",
      "Bash(git -C * branch -vv)",
      "Bash(git -C * blame *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * cat-file *)",
      "Bash(git -C * for-each-ref *)",
      "Bash(git -C * describe *)",
      "Bash(git -C * shortlog *)",
      "Bash(git -C * reflog)",
      "Bash(git -C * reflog *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git ls-tree *)",
      "Bash(git ls-files *)",
      "Bash(git remote -v)",
      "Bash(git worktree list)",
      "Bash(git branch)",
      "Bash(git branch -v)",
      "Bash(git branch -vv)",
      "Bash(git blame *)",
      "Bash(git rev-parse *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list)",
      "Bash(gh issue list *)",
      "Bash(gh run view *)",
      "Bash(gh run list)",
      "Bash(gh run list *)",
      "Bash(gh repo view *)",
      "Bash(gh auth status)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(stat *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // \"\"'); if echo \"$cmd\" | grep -q 'ssh oxygen-mvp'; then in_progress=$(grep -c '\\[~\\]' /Users/gordonwong/claude-projects/oxygen-mvp/TASKS.md 2>/dev/null || echo 0); if [ \"$in_progress\" -eq 0 ]; then echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"TASK WARNING: You are about to run an EC2 command but there is no in-progress task ([~]) in TASKS.md. Create or mark a task [~] in TASKS.md before proceeding with EC2 work.\"}}'; else echo '{}'; fi; else echo '{}'; fi",
            "statusMessage": "Checking task status..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"Stop\", \"additionalContext\": \"LOGGING REMINDER: Before ending this session, verify LOG.md and TASKS.md are current. Log format: HH:MM ET timestamp. Check: (1) any completed tasks marked [x] in TASKS.md, (2) decisions/blockers added to LOG.md, (3) Current Status and Last Updated fields updated.\"}}'",
            "statusMessage": "Checking log compliance..."
          }
        ]
      }
    ]
  }
}
